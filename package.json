{
  "name": "tichuml",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "clean": "rimraf apps/web/dist apps/server/dist apps/sim-runner/dist packages/shared/dist packages/engine/dist packages/telemetry/dist packages/ai-heuristics/dist packages/ui-kit/dist coverage",
    "lint": "eslint .",
    "test": "vitest run",
    "dev:web": "npm run dev -w @tichuml/web",
    "dev:server": "npm run dev -w @tichuml/server",
    "start:server": "npm run start -w @tichuml/server",
    "bootstrap:windows": "powershell -ExecutionPolicy Bypass -File scripts/bootstrap.ps1",
    "bootstrap:unix": "bash scripts/bootstrap.sh",
    "build": "npm run clean && npm run build:shared && npm run build:engine && npm run build:telemetry && npm run build:ai && npm run build:ui-kit && npm run build:server && npm run build:sim-runner && npm run build:web",
    "build:shared": "npm run build -w @tichuml/shared",
    "build:engine": "npm run build -w @tichuml/engine",
    "build:telemetry": "npm run build -w @tichuml/telemetry",
    "build:ai": "npm run build -w @tichuml/ai-heuristics",
    "build:ui-kit": "npm run build -w @tichuml/ui-kit",
    "build:server": "npm run build -w @tichuml/server",
    "build:sim-runner": "npm run build -w @tichuml/sim-runner",
    "build:web": "npm run build -w @tichuml/web",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "tsx infra/db/scripts/migrate.ts",
    "db:migrate:status": "tsx infra/db/scripts/migrate.ts status",
    "sim": "tsx apps/sim-runner/src/cli.ts",
    "selfplay:validate-short-games": "npm run build:shared && npm run build:engine && npm run build:telemetry && npm run build:ai && npm run build:sim-runner && tsx apps/sim-runner/src/selfplay-validate-short-games.ts",
    "sim:diag": "tsx scripts/sim-diagnostics.ts",
    "sim:doctor": "tsx scripts/sim-doctor.ts",
    "sim:doctor:linux": "bash scripts/sim-doctor.sh",
    "sim:training:linux": "bash scripts/run-training-sim.sh",
    "telemetry:truth": "tsx scripts/telemetry-truth.ts",
    "telemetry:sanity": "tsx scripts/telemetry-sanity.ts",
    "telemetry:write-amplification": "tsx scripts/telemetry-write-amplification.ts",
    "telemetry:finalize-results": "tsx scripts/telemetry-finalize-results.ts",
    "telemetry:validate-training-data": "tsx scripts/telemetry-validate-training-data.ts",
    "telemetry:validate-run": "tsx scripts/telemetry-validate-run.ts",
    "telemetry:ready": "tsx scripts/training-data.ts readiness-loop",
    "verify:sim:one:windows": "powershell -ExecutionPolicy Bypass -File scripts/verify-sim-one-game.ps1",
    "verify:sim:one:linux": "bash scripts/verify-sim-one-game.sh",
    "telemetry:replay": "tsx apps/sim-runner/src/telemetry/replay.ts",
    "ml:export": "tsx scripts/run-python.ts ml/export_training_rows.py",
    "ml:rollouts": "tsx apps/sim-runner/src/ml-rollouts.ts",
    "ml:train": "tsx scripts/run-python.ts ml/train_lightgbm.py",
    "ml:bootstrap": "tsx scripts/ml-bootstrap.ts",
    "ml:evaluate": "tsx apps/sim-runner/src/evaluate.ts"
  },
